rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Personal uploads — only the owning user can read or write their files,
    // and each uploaded file must be ≤ 10 MB.
    match /users/{userId}/documents/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null &&
                      request.auth.uid == userId &&
                      request.resource.size <= 10 * 1024 * 1024;
    }

    // Room shared files — any authenticated user can read room files.
    // Writes are limited to authenticated users uploading files ≤ 10 MB.
    // Room membership is enforced at the Firestore layer, not here.
    match /rooms/{roomId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                      request.resource.size <= 10 * 1024 * 1024;
    }
  }
}

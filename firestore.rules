rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Subcollection membership check — safe for single-doc operations and
    // subcollection rules, but NOT for list queries (see rooms read rule).
    function isRoomMember(roomId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function isRoomOwner(roomId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid)).data.role == 'owner';
    }

    // ── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── documents ────────────────────────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (resource.data.roomId != null && isRoomMember(resource.data.roomId))
      );
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ── rooms ─────────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow create: if isSignedIn();

      // Must check resource.data.members (the denormalized top-level array) rather
      // than isRoomMember() so Firestore can validate the array-contains list query
      // in roomService.js. isRoomMember() uses exists() against a different path and
      // causes permission-denied on collection queries.
      // CONTRACT: room docs must carry members: string[] kept in sync with the subcollection.
      allow read:   if isSignedIn() && request.auth.uid in resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow delete: if isRoomOwner(roomId);

      match /members/{userId} {
        allow read:           if isRoomMember(roomId);
        allow create:         if isSignedIn() && request.auth.uid == userId;
        allow update, delete: if isRoomOwner(roomId);
      }

      match /shared-documents/{docId} {
        allow read, create:   if isRoomMember(roomId);
        allow update, delete: if isRoomOwner(roomId);
      }

      match /messages/{messageId} {
        allow read, create:   if isRoomMember(roomId);
        allow update, delete: if false;
      }
    }

    // ── quiz_attempts ─────────────────────────────────────────────────────────
    match /quiz_attempts/{attemptId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.user_id;
    }

    // ── sessions ──────────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow create:             if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}

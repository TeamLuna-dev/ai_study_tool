# ── Backend ───────────────────────────────────────────────────────────────
DEV_MODE=true (development without Firebase) or false (production with Firebase)
DEV_UID=test-user-123

OPENAI_API_KEY=paste_your_key_here
UNSTRUCTURED_API_KEY=paste_your_key_here
CHUNKING_STRATEGY=fast, auto, hi_res, or character

GOOGLE_APPLICATION_CREDENTIALS=path/to/your/backend/serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket-name

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=paste_your_key_here

# ── Frontend (Vite exposes VITE_ prefix only) ─────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket-name
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id

FIREBASE_SERVICE_ACCOUNT_JSON=minimized-firebase-account-credentials